# Template for `backend/.env` (the real file is gitignored — you should see `.env` next to this file locally).
# New clone: copy this file → `.env`  (PowerShell: Copy-Item .env.example .env)
# Only SPOTIFY_CLIENT_ID is required for PKCE sign-in.
# If playlist create/edit/read returns HTTP 403 (often message "Forbidden"): Sign out → Connect so the token picks up playlist scopes (playlist-modify-*, playlist-read-private, playlist-read-collaborative). Spotify refresh tokens do NOT upgrade to newer scopes — they carry only what was granted at the original /authorize consent, so adding scopes in code requires a fresh sign-in. Tool errors now include granted_scopes/missing_scopes and spotify_me includes granted_scopes for diagnosis.
# Feb 2026 Spotify Web API migration: dev-mode apps must use /playlists/{id}/items (not /tracks) for add/remove/reorder/replace/list, and playlist response field `tracks` was renamed to `items`. GET /artists/{id}/top-tracks was removed for dev-mode apps (this backend falls back to search-by-artist-name). /search `limit` max is now 10 (default 5). See https://developer.spotify.com/blog/2026-02-06-update-on-developer-access-and-platform-security and the migration guide https://developer.spotify.com/documentation/web-api/tutorials/february-2026-migration-guide — if you see a 403 with scopes_appear_sufficient:true and ownership verified, it usually means a newly-affected endpoint the backend has not yet migrated.
# SPOTIFY_SHOW_DIALOG=false  # omit or false to skip forcing the Spotify consent screen on every /login (default true).
SPOTIFY_CLIENT_ID=

# Optional: classic confidential OAuth only — leave empty for normal PKCE sign-in.
# SPOTIFY_CLIENT_SECRET=

SPOTIFY_REDIRECT_URI=http://127.0.0.1:8765/callback

API_HOST=127.0.0.1
API_PORT=8765
FRONTEND_ORIGIN=http://localhost:5173

# LLM: ollama (local) or gemini (Google AI Studio API key). The UI can override provider and model (Ollama or Gemini) without editing .env
# (stored in DATA_DIR/llm_provider.json). Use "Reset to .env" in the app to clear the provider override; pick "From .env (…)" in the model dropdown to clear a model override.
# The UI model dropdowns are populated at runtime from what the active provider reports: `ollama list` for Ollama, the Google Generative Language models API for Gemini. OLLAMA_MODEL / GEMINI_MODEL below are the defaults used when no UI override is active.
LLM_PROVIDER=ollama

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2:2b
# Ollama's default context is 4096 tokens; Spot-AI-fy's system prompt + chat history +
# tool results routinely exceed that, causing Ollama to silently truncate the prompt
# (look for "truncating input prompt" in %LOCALAPPDATA%\Ollama\server.log). 8192 is a
# safe default for 8B-class models on a 16 GB machine. Set to 0 to use the model default.
OLLAMA_NUM_CTX=8192
# Keep the model resident between requests so you don't pay the cold-load penalty
# (can be 1–2 minutes on CPU). Accepts Ollama duration strings ("30m", "2h", "-1").
OLLAMA_KEEP_ALIVE=30m
# --- CPU-focused Ollama tuning (all three default to off / unlimited) ---
# Only keep the last N messages from the UI chat log when talking to Ollama. Every
# agent round re-processes the full prompt, so history length multiplies CPU time.
# Recommended for CPU-only: 8–12. 0 = keep everything the UI sent (currently 40).
OLLAMA_HISTORY_MESSAGES=0
# Character cap for each tool result fed back into Ollama. 12000 is the built-in cap;
# tightening to 4000–6000 keeps big JSON blobs (playlists, search results) from eating
# context and costing prompt-eval time on every subsequent round.
OLLAMA_TOOL_RESULT_MAX=0
# Agent step cap specifically for Ollama. 0 = use AGENT_MAX_STEPS. Set to 6–8 on CPU
# so a confused local model bails out of tool loops faster.
OLLAMA_MAX_STEPS=0

# When LLM_PROVIDER=gemini — create a key at https://aistudio.google.com/apikey
# If you see HTTP 429 / quota / limit:0, enable billing or check limits: https://ai.google.dev/gemini-api/docs/rate-limits
# If you see HTTP 404, GEMINI_MODEL is wrong or retired for your key — try gemini-2.5-flash or list models at https://ai.google.dev/api/rest/v1beta/models/list
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: markdown file appended to the Spot-AI-fy system prompt (Ollama + Gemini). See backend/AGENT_CONTEXT.example.md
# AGENT_CONTEXT_FILE=C:\path\to\my-agent-context.md

# Optional: override where tokens/device are stored (defaults to %USERPROFILE%\.spot_ai_fy on Windows)
# DATA_DIR=C:\Users\you\.spot_ai_fy
